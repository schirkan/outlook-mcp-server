<?xml version="1.0" encoding="utf-8"?>
<!--
  Publish-Profil "minimal" fuer OutlookMcpServer (Outlook MCP Server).

  Ziel: minimale Dateigroesse bei lauffaehigem self-contained Windows-x64 Build.

  Optionen (Begruendung siehe DECISIONS.md):
  - PublishSingleFile           : 1 .exe statt vieler DLLs (Komfort + Deployment)
  - SelfContained               : .NET-Runtime enthalten (keine .NET-Installation
                                   auf Zielmaschine noetig)
  - PublishTrimmed              : ungenutzte BCL/MCP-SDK/Microsoft.Extensions-Teile
                                   werden vom Trimmer entfernt
  - TrimMode=partial            : konservativer Trimmer — reflection-relevante Typen
                                   bleiben erhalten (MCP [McpServerToolType],
                                   DI-Container, COM-dynamic-Late-Binding ueber
                                   Microsoft.Office.Interop.Outlook-PIA).
                                   HINWEIS: full-Trim wuerde ~10-20 % mehr sparen,
                                   ist aber mit dynamic-Calls und Reflection-Guards
                                   der MCP-SDK-Preview riskant.
  - EnableCompressionInSingleFile: Single-File wird beim Build komprimiert und zur
                                   Laufzeit in ein Temp-Dir extrahiert. Spart je
                                   nach Runtime ~30-50 % File-Size.
  - DebugType=embedded          : PDB inline in der Assembly, keine separate .pdb.
  - InvariantGlobalization      : keine ICU-/culture-Daten (App braucht keine
                                   Culture-Info). Spart bei Self-Contained ~3-4 MB.

  Verwendung:
    dotnet publish src/OutlookMcpServer/OutlookMcpServer.csproj ^
      -c Release ^
      -r win-x64 ^
      -p:PublishProfile=src/OutlookMcpServer/Properties/PublishProfiles/minimal.pubxml

  Output:
    src/OutlookMcpServer/bin/Release/net8.0-windows/win-x64/publish/OutlookMcpServer.exe

  Voraussetzungen: Outlook (klassischer Desktop-Client, siehe VISION.md) muss
  auf der Zielmaschine installiert sein — der MCP-Server spricht via COM-Interop
  mit dem aktiven Outlook-Profil des angemeldeten Windows-Benutzers.
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>AnyCPU</Platform>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <PublishSingleFile>true</PublishSingleFile>
    <SelfContained>true</SelfContained>
    <PublishTrimmed>true</PublishTrimmed>
    <TrimMode>partial</TrimMode>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <DebugType>embedded</DebugType>
    <InvariantGlobalization>true</InvariantGlobalization>
    <UseAppHost>true</UseAppHost>
  </PropertyGroup>
</Project>