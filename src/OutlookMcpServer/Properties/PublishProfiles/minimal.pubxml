<?xml version="1.0" encoding="utf-8"?>
<!--
  Publish-Profil "minimal" fuer OutlookMcpServer (Outlook MCP Server).

  Ziel: minimale Dateigroesse bei lauffaehigem self-contained Windows-x64 Build,
  der COM-Interop mit Outlook unterstuetzt.

  Optionen (Begruendung siehe DECISIONS.md):
  - PublishSingleFile           : 1 .exe statt vieler DLLs (Komfort + Deployment)
  - SelfContained               : .NET-Runtime enthalten (keine .NET-Installation
                                   auf Zielmaschine noetig)
  - PublishTrimmed              : DEAKTIVIERT — der .NET-Host setzt bei aktivem Trim
                                   den Runtime-Feature-Switch
                                   System.Runtime.InteropServices.BuiltInComInterop.IsSupported
                                   hart auf false, was ALLE COM-Aktivierungswege
                                   blockiert (Marshal.GetTypeFromProgID,
                                   GetObjectForIUnknown, [ComImport]-CoClass).
                                   Folge: NotSupportedException beim ersten
                                   Outlook-Aufruf. Bleibt daher zwingend false;
                                   Abweichung wuerde sofort die Mail/Calendar-Tools
                                   brechen. Erklaerung in DECISIONS.md.
  - PublishReadyToRun           : Ahead-of-Time-Kompilierung der Runtime und
                                   unseres Codes in x86-64 Maschinencode.
                                   Spart Startzeit (~3x schnellerer JIT-Startup)
                                   UND reduziert die File-Size um ~30-40 %
                                   im Vergleich zu einem reinen JIT-Build.
                                   Erlaubt weiterhin Reflection und COM — im
                                   Gegensatz zu Trimming.
  - PublishReadyToRunComposite  : Erzeugt eine einzige R2R-Datei fuer alle
                                   Framework-Dependencies (statt vieler kleiner
                                   .ni.dll-Dateien).
  - EnableCompressionInSingleFile: Single-File wird beim Build komprimiert und zur
                                   Laufzeit in ein Temp-Dir extrahiert. Spart je
                                   nach Runtime ~30-50 % File-Size.
  - DebugType=embedded          : PDB inline in der Assembly, keine separate .pdb.
  - InvariantGlobalization      : keine ICU-/culture-Daten (App braucht keine
                                   Culture-Info). Spart bei Self-Contained ~3-4 MB.

  Verwendung:
    dotnet publish src/OutlookMcpServer/OutlookMcpServer.csproj ^
      -c Release ^
      -r win-x64 ^
      -p:PublishProfile=src/OutlookMcpServer/Properties/PublishProfiles/minimal.pubxml

  Output:
    src/OutlookMcpServer/bin/Release/net8.0-windows/win-x64/publish/OutlookMcpServer.exe

  Voraussetzungen: Outlook (klassischer Desktop-Client, siehe VISION.md) muss
  auf der Zielmaschine installiert sein — der MCP-Server spricht via COM-Interop
  mit dem aktiven Outlook-Profil des angemeldeten Windows-Benutzers.
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>AnyCPU</Platform>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <PublishSingleFile>true</PublishSingleFile>
    <SelfContained>true</SelfContained>
    <!-- PublishTrimmed + TrimMode muessen zwingend false/aus sein, sonst blockiert
         der .NET-Host BuiltInComInterop.IsSupported = false und keine COM-Aktivierung
         (auch nicht via [ComImport]-CoClass) funktioniert. Siehe DECISIONS.md. -->
    <PublishTrimmed>false</PublishTrimmed>
    <!--
      PublishReadyToRun wurde getestet, lohnt sich fuer Single-File + Compression
      aber NICHT: die R2R-Payloads werden zusaetzlich zur MSIL eingepackt und
      komprimieren schlechter als reiner JIT-Code. Ergebnis: EXE mit R2R
      (54 MB) ist sogar groesser als ohne R2R (45 MB). Bleibt daher deaktiviert.
    -->
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <DebugType>embedded</DebugType>
    <InvariantGlobalization>true</InvariantGlobalization>
    <UseAppHost>true</UseAppHost>
  </PropertyGroup>
</Project>